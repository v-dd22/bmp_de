<!-- ═══════════════════════════════════════════════════════════════════════
     APPLICATION JAVASCRIPT
═══════════════════════════════════════════════════════════════════════ -->
<script>
// ─── STATE CACHE ──────────────────────────────────────────────────────────
let _purchases = [], _sales = [], _inventory = [], _vendors = [], _customers = [];
let _expenses = [], _vendorPays = [], _custReceipts = [], _users = [];

// ─── UI HELPERS ───────────────────────────────────────────────────────────
function showLogin() {
  document.getElementById("loginScreen").style.display = "flex";
  document.getElementById("app").classList.remove("visible");
}

function showApp() {
  document.getElementById("loginScreen").style.display = "none";
  document.getElementById("app").classList.add("visible");
  applyRoleUI();
  loadCompanies();
  loadUsers();
  setTodayDefaults();
}

function applyRoleUI() {
  const role = window.APP.userRole;
  const user = window.APP.user;
  // Update header
  const av = document.getElementById("userAvatar");
  av.textContent = (user?.name || "U")[0].toUpperCase();
  document.getElementById("userName").textContent = user?.name || user?.email || "User";
  const rt = document.getElementById("roleTag");
  rt.textContent = role;
  rt.className = "role-tag role-" + role;

  // Show/hide nav sections
  document.getElementById("navAdmin").style.display = role === "admin" ? "block" : "none";
  document.getElementById("navExpenses").style.display = (role === "admin") ? "block" : "none";

  if (role === "sales") {
    document.getElementById("navPurchase").style.display = "none";
  }
  if (role === "purchase") {
    document.getElementById("navSales").style.display = "none";
  }
}

function navigate(page) {
  // Check access
  const role = window.APP.userRole;
  const blocked = {
    sales: ["purchases", "vendors", "expenses", "companies", "users"],
    purchase: ["sales", "customers", "invoices", "companies", "users"]
  };
  if (blocked[role] && blocked[role].includes(page)) {
    showToast("Access restricted for your role", "error"); return;
  }
  if (!window.APP.activeCompany && !["companies", "users"].includes(page)) {
    showToast("Please select or add a company first", "error"); return;
  }

  document.querySelectorAll(".page").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".nav-item").forEach(n => n.classList.remove("active"));
  const pg = document.getElementById("page-" + page);
  if (pg) pg.classList.add("active");
  const ni = document.querySelector(`[data-page="${page}"]`);
  if (ni) ni.classList.add("active");

  if (page === "dashboard") loadDashboard();
  if (page === "purchases") loadPurchases();
  if (page === "sales") loadSalesPage();
  if (page === "inventory") loadInventory();
  if (page === "vendors") loadVendors();
  if (page === "customers") loadCustomers();
  if (page === "expenses") loadExpenses();
  if (page === "cashflow") loadCashflow();
  if (page === "invoices") loadInvoices();
  if (page === "companies") renderCompaniesList();
  if (page === "users") loadUsersPage();
}

function openModal(id) { document.getElementById(id).classList.add("open"); }
function closeModal(id) { document.getElementById(id).classList.remove("open"); }

function showToast(msg, type = "success") {
  const t = document.createElement("div");
  t.className = `toast toast-${type}`;
  t.innerHTML = (type === "success" ? "✓" : "✕") + " " + msg;
  document.getElementById("toastContainer").appendChild(t);
  setTimeout(() => t.remove(), 3500);
}

function fmt(n) {
  const v = parseFloat(n) || 0;
  return "₹" + v.toLocaleString("en-IN", { maximumFractionDigits: 2 });
}
function fmtDate(ts) {
  if (!ts) return "—";
  const d = ts.toDate ? ts.toDate() : new Date(ts);
  return d.toLocaleDateString("en-IN");
}
function setTodayDefaults() {
  const today = new Date().toISOString().split("T")[0];
  ["pur_date","sal_date","exp_date"].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = today;
  });
}

// ─── COMPANY TABS ─────────────────────────────────────────────────────────
function renderCompanyTabs() {
  const tabs = document.getElementById("companyTabs");
  tabs.innerHTML = "";
  window.APP.companies.forEach(c => {
    const btn = document.createElement("button");
    btn.className = "company-tab" + (c.id === window.APP.activeCompany ? " active" : "");
    btn.textContent = c.name;
    btn.onclick = () => selectCompany(c.id);
    tabs.appendChild(btn);
  });
  if (window.APP.companies.length > 0) {
    document.getElementById("noCompany").style.display = "none";
  }
}

// ─── DASHBOARD ────────────────────────────────────────────────────────────
function loadDashboard() {
  const cid = window.APP.activeCompany;
  if (!cid) return;
  const co = window.APP.companies.find(c => c.id === cid);
  document.getElementById("dashCompanyName").textContent = co ? co.name : "";

  subscribeCollection(`companies/${cid}/sales`, data => {
    _sales = data;
    const total = data.reduce((s, r) => s + (r.total || 0), 0);
    document.getElementById("statSales").textContent = fmt(total);
    document.getElementById("statSalesCount").textContent = data.length + " transactions";
    renderRecentSales(data.slice(-5).reverse());
    updateDashDerived();
  });

  subscribeCollection(`companies/${cid}/purchases`, data => {
    _purchases = data;
    const total = data.reduce((s, r) => s + (r.total || 0), 0);
    document.getElementById("statPurchases").textContent = fmt(total);
    document.getElementById("statPurchasesCount").textContent = data.length + " transactions";
    renderRecentPurchases(data.slice(-5).reverse());
    updateDashDerived();
  });

  subscribeCollection(`companies/${cid}/inventory`, data => {
    _inventory = data;
    document.getElementById("statInventory").textContent = data.length;
  });

  subscribeCollection(`companies/${cid}/vendors`, data => {
    _vendors = data;
    const payable = data.reduce((s, r) => s + (r.payable || 0), 0);
    document.getElementById("statPayable").textContent = fmt(payable);
  });

  subscribeCollection(`companies/${cid}/customers`, data => {
    _customers = data;
    const recv = data.reduce((s, r) => s + (r.receivable || 0), 0);
    document.getElementById("statReceivable").textContent = fmt(recv);
  });

  subscribeCollection(`companies/${cid}/expenses`, data => {
    _expenses = data;
    const total = data.reduce((s, r) => s + (r.amount || 0), 0);
    document.getElementById("statExpenses").textContent = fmt(total);
    updateDashDerived();
  });

  subscribeCollection(`companies/${cid}/vendorPayments`, data => {
    _vendorPays = data;
    updateDashDerived();
  });

  subscribeCollection(`companies/${cid}/customerReceipts`, data => {
    _custReceipts = data;
    updateDashDerived();
  });
}

function updateDashDerived() {
  const salesTotal = _sales.reduce((s, r) => s + (r.total || 0), 0);
  const purchasesTotal = _purchases.reduce((s, r) => s + (r.total || 0), 0);
  const expTotal = _expenses.reduce((s, r) => s + (r.amount || 0), 0);
  const received = _custReceipts.reduce((s, r) => s + (r.amount || 0), 0)
    + _sales.filter(s => s.payMode === "cash" || s.payMode === "upi" || s.payMode === "bank")
            .reduce((s, r) => s + (r.amtReceived || r.total || 0), 0);
  const paid = _vendorPays.reduce((s, r) => s + (r.amount || 0), 0)
    + _purchases.filter(p => p.payMode === "cash" || p.payMode === "upi" || p.payMode === "bank")
                .reduce((s, r) => s + (r.amtPaid || 0), 0);
  const cash = received - paid - expTotal;
  document.getElementById("statProfit").textContent = fmt(salesTotal - purchasesTotal);
  document.getElementById("statCash").textContent = fmt(cash);
}

function renderRecentSales(data) {
  const tb = document.getElementById("recentSales");
  if (!data.length) { tb.innerHTML = '<tr><td colspan="4" class="empty-row">No sales yet</td></tr>'; return; }
  tb.innerHTML = data.map(s => `
    <tr><td>${fmtDate(s.date || s.createdAt)}</td><td>${s.customerName || "—"}</td>
    <td class="text-mono">${fmt(s.total)}</td>
    <td><span class="badge ${s.unpaidAmount > 0 ? 'badge-yellow' : 'badge-green'}">${s.unpaidAmount > 0 ? 'Partial' : 'Paid'}</span></td></tr>
  `).join("");
}

function renderRecentPurchases(data) {
  const tb = document.getElementById("recentPurchases");
  if (!data.length) { tb.innerHTML = '<tr><td colspan="4" class="empty-row">No purchases yet</td></tr>'; return; }
  tb.innerHTML = data.map(p => `
    <tr><td>${fmtDate(p.date || p.createdAt)}</td><td>${p.vendorName || "—"}</td>
    <td class="text-mono">${fmt(p.total)}</td>
    <td><span class="badge ${p.unpaidAmount > 0 ? 'badge-yellow' : 'badge-green'}">${p.unpaidAmount > 0 ? 'Partial' : 'Paid'}</span></td></tr>
  `).join("");
}

// ─── PURCHASES ────────────────────────────────────────────────────────────
function loadPurchases() {
  const cid = window.APP.activeCompany; if (!cid) return;
  subscribeCollection(`companies/${cid}/purchases`, data => {
    _purchases = data;
    const sorted = [...data].sort((a,b) => (b.createdAt?.seconds||0) - (a.createdAt?.seconds||0));
    const tb = document.getElementById("purchasesTable");
    if (!sorted.length) { tb.innerHTML = '<tr><td colspan="8" class="empty-row">No purchases yet. Add your first purchase.</td></tr>'; return; }
    tb.innerHTML = sorted.map(p => `
      <tr>
