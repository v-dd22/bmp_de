<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TradeFlow — Business Management Platform</title>

<!-- Firebase SDK -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged, createUserWithEmailAndPassword }
    from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
  import { getFirestore, collection, doc, addDoc, setDoc, getDoc, getDocs, updateDoc, deleteDoc,
    query, where, orderBy, onSnapshot, serverTimestamp, increment, writeBatch }
    from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

  // ─── FIREBASE CONFIG ──────────────────────────────────────────────────────
  const firebaseConfig = {
    apiKey: "AIzaSyBNzUTuem8ZfOI8dG8I5BCMqrusgFpW-qA",
    authDomain: "bmp-de.firebaseapp.com",
    projectId: "bmp-de",
    storageBucket: "bmp-de.firebasestorage.app",
    messagingSenderId: "321766515857",
    appId: "1:321766515857:web:11cf4a934336467fe18b30"
  };

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);

  // ─── GLOBAL STATE ─────────────────────────────────────────────────────────
  window.APP = {
    auth, db,
    user: null,
    userRole: null,        // 'admin' | 'sales' | 'purchase'
    activeCompany: null,   // company id
    companies: [],
    listeners: [],         // active Firestore listeners to unsubscribe
    cache: {
      inventory: {},
      vendors: {},
      customers: {},
    }
  };

  // ─── AUTH STATE ───────────────────────────────────────────────────────────
  onAuthStateChanged(auth, async (user) => {
    if (user) {
      const snap = await getDoc(doc(db, "users", user.uid));
      const data = snap.exists() ? snap.data() : { role: "sales", name: user.email };
      window.APP.user = { uid: user.uid, email: user.email, ...data };
      window.APP.userRole = data.role || "sales";
      showApp();
    } else {
      window.APP.user = null;
      window.APP.userRole = null;
      showLogin();
    }
  });

  // ─── COMPANIES ────────────────────────────────────────────────────────────
  window.loadCompanies = async () => {
    const snap = await getDocs(collection(db, "companies"));
    window.APP.companies = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    renderCompanyTabs();
    if (window.APP.companies.length > 0 && !window.APP.activeCompany) {
      selectCompany(window.APP.companies[0].id);
    }
  };

  window.addCompany = async (name, gstin, address) => {
    const ref = await addDoc(collection(db, "companies"), {
      name, gstin, address, createdAt: serverTimestamp()
    });
    await loadCompanies();
    return ref.id;
  };

  window.selectCompany = (id) => {
    window.APP.activeCompany = id;
    // Unsubscribe old listeners
    window.APP.listeners.forEach(u => u());
    window.APP.listeners = [];
    renderCompanyTabs();
    loadDashboard();
  };

  // ─── INVENTORY ────────────────────────────────────────────────────────────
  window.addPurchase = async (data) => {
    const cid = window.APP.activeCompany;
    const batch = writeBatch(db);
    const purchaseRef = doc(collection(db, "companies", cid, "purchases"));
    batch.set(purchaseRef, { ...data, createdAt: serverTimestamp() });

    // Update inventory for each item
    for (const item of data.items) {
      const invRef = doc(db, "companies", cid, "inventory", item.productId);
      batch.set(invRef, {
        productName: item.productName,
        unit: item.unit,
        qty: increment(item.qty),
        avgCost: item.unitPrice,
        updatedAt: serverTimestamp()
      }, { merge: true });
    }

    // Update vendor payable
    const vendorRef = doc(db, "companies", cid, "vendors", data.vendorId);
    batch.set(vendorRef, {
      name: data.vendorName,
      payable: increment(data.unpaidAmount),
      updatedAt: serverTimestamp()
    }, { merge: true });

    await batch.commit();
    showToast("Purchase recorded successfully", "success");
  };

  window.addSale = async (data) => {
    const cid = window.APP.activeCompany;
    const batch = writeBatch(db);
    const saleRef = doc(collection(db, "companies", cid, "sales"));
    batch.set(saleRef, { ...data, createdAt: serverTimestamp() });

    // Reduce inventory
    for (const item of data.items) {
      const invRef = doc(db, "companies", cid, "inventory", item.productId);
      batch.set(invRef, {
        qty: increment(-item.qty),
        updatedAt: serverTimestamp()
      }, { merge: true });
    }

    // Update customer receivable
    const custRef = doc(db, "companies", cid, "customers", data.customerId);
    batch.set(custRef, {
      name: data.customerName,
      receivable: increment(data.unpaidAmount),
      updatedAt: serverTimestamp()
    }, { merge: true });

    await batch.commit();
    showToast("Sale recorded successfully", "success");
  };

  window.recordVendorPayment = async (vendorId, vendorName, amount, note) => {
    const cid = window.APP.activeCompany;
    const batch = writeBatch(db);
    const txRef = doc(collection(db, "companies", cid, "vendorPayments"));
    batch.set(txRef, { vendorId, vendorName, amount, note, createdAt: serverTimestamp() });
    const vendorRef = doc(db, "companies", cid, "vendors", vendorId);
    batch.set(vendorRef, { payable: increment(-amount), updatedAt: serverTimestamp() }, { merge: true });
    await batch.commit();
    showToast("Vendor payment recorded", "success");
  };

  window.recordCustomerReceipt = async (customerId, customerName, amount, note) => {
    const cid = window.APP.activeCompany;
    const batch = writeBatch(db);
    const txRef = doc(collection(db, "companies", cid, "customerReceipts"));
    batch.set(txRef, { customerId, customerName, amount, note, createdAt: serverTimestamp() });
    const custRef = doc(db, "companies", cid, "customers", customerId);
    batch.set(custRef, { receivable: increment(-amount), updatedAt: serverTimestamp() }, { merge: true });
    await batch.commit();
    showToast("Customer receipt recorded", "success");
  };

  window.addExpense = async (data) => {
    const cid = window.APP.activeCompany;
    await addDoc(collection(db, "companies", cid, "expenses"), { ...data, createdAt: serverTimestamp() });
    showToast("Expense added", "success");
  };

  // ─── REALTIME LISTENERS ──────────────────────────────────────────────────
  window.subscribeCollection = (path, callback) => {
    const unsubscribe = onSnapshot(collection(db, ...path.split("/")), (snap) => {
      const data = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      callback(data);
    });
    window.APP.listeners.push(unsubscribe);
  };

  // ─── AUTH HELPERS ─────────────────────────────────────────────────────────
  window.doLogin = async (email, password) => {
    try {
      await signInWithEmailAndPassword(auth, email, password);
    } catch (e) {
      showToast("Login failed: " + e.message, "error");
    }
  };

  window.doLogout = () => signOut(auth);

  window.createUser = async (email, password, name, role) => {
    try {
      const cred = await createUserWithEmailAndPassword(auth, email, password);
      await setDoc(doc(db, "users", cred.user.uid), { name, role, email, createdAt: serverTimestamp() });
      showToast(`User ${name} created with role: ${role}`, "success");
    } catch (e) {
      showToast("Error creating user: " + e.message, "error");
    }
  };

  // ─── EXPORT HELPERS ───────────────────────────────────────────────────────
  window.exportToCSV = (data, filename) => {
    if (!data || data.length === 0) { showToast("No data to export", "error"); return; }
    const keys = Object.keys(data[0]).filter(k => k !== 'id');
    const csv = [keys.join(","), ...data.map(row =>
      keys.map(k => `"${String(row[k] ?? '').replace(/"/g, '""')}"`).join(",")
    )].join("\n");
    const a = document.createElement("a");
    a.href = URL.createObjectURL(new Blob([csv], { type: "text/csv" }));
    a.download = filename + ".csv";
    a.click();
  };

  console.log("Firebase initialized. Configure firebaseConfig above with your project credentials.");
</script>

<style>
