.form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }

/* ─── ITEM LINE ──────────────────────────────────────────────────────────── */
.item-lines { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
.item-line { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 28px;
  gap: 8px; padding: 10px 12px; background: var(--bg3); border-bottom: 1px solid var(--border); align-items: center; }
.item-line:last-child { border-bottom: none; }
