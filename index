  font-size: 16px; line-height: 1; padding: 0; transition: color 0.15s; }
.remove-line:hover { color: var(--red); }

/* ─── GST INVOICE ────────────────────────────────────────────────────────── */
#invoicePreview {
  background: #fff; color: #111; padding: 40px;
  font-family: 'DM Sans', sans-serif; max-width: 800px; margin: 0 auto;
}
.inv-header { display: flex; justify-content: space-between; align-items: flex-start;
  border-bottom: 2px solid #1a1a2e; padding-bottom: 20px; margin-bottom: 20px; }
.inv-company-name { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 800; color: #1a1a2e; }
.inv-title { font-size: 28px; font-weight: 800; color: #1a1a2e; text-align: right; }
.inv-subtitle { font-size: 12px; color: #666; }
.inv-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
.inv-info-block h4 { font-size: 11px; font-weight: 700; text-transform: uppercase; color: #666; margin-bottom: 6px; }
.inv-info-block p { font-size: 13px; line-height: 1.6; color: #111; }
.inv-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
.inv-table th { background: #1a1a2e; color: #fff; padding: 10px 12px; text-align: left; font-size: 12px; }
.inv-table td { padding: 9px 12px; border-bottom: 1px solid #eee; font-size: 13px; }
.inv-total-section { display: flex; justify-content: flex-end; margin-top: 12px; }
.inv-total-box { width: 280px; }
.inv-total-row { display: flex; justify-content: space-between; padding: 6px 0;
  border-bottom: 1px solid #eee; font-size: 13px; }
.inv-total-row.grand { font-weight: 700; font-size: 16px; color: #1a1a2e; border-bottom: 2px solid #1a1a2e; }
.inv-footer { margin-top: 40px; border-top: 1px solid #eee; padding-top: 16px;
  display: flex; justify-content: space-between; font-size: 12px; color: #666; }

/* ─── TOAST ──────────────────────────────────────────────────────────────── */
#toastContainer { position: fixed; top: 20px; right: 20px; z-index: 9999;
  display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
.toast { padding: 12px 18px; border-radius: var(--radius); font-size: 13px; font-weight: 600;
  box-shadow: var(--shadow); animation: toastIn 0.3s ease;
  display: flex; align-items: center; gap: 8px; pointer-events: auto; }
.toast-success { background: #0f2419; border: 1px solid rgba(52,211,153,0.3); color: var(--green); }
.toast-error { background: #1f0f0f; border: 1px solid rgba(248,113,113,0.3); color: var(--red); }
@keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

/* ─── MINI CHART ─────────────────────────────────────────────────────────── */
.chart-bar-wrap { display: flex; align-items: flex-end; gap: 3px; height: 40px; }
.chart-bar { flex: 1; background: var(--accent); border-radius: 3px 3px 0 0; opacity: 0.6; min-height: 2px; }

/* ─── PRINT ──────────────────────────────────────────────────────────────── */
@media print {
  body * { visibility: hidden; }
  #invoicePreview, #invoicePreview * { visibility: visible; }
  #invoicePreview { position: fixed; left: 0; top: 0; width: 100%; }
}

/* ─── RESPONSIVE ──────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  #sidebar { display: none; }
  .form-row, .form-row-3 { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .item-line { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; }
  .item-header { display: none; }
}

.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.section-divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }
.text-right { text-align: right; }
.text-mono { font-family: var(--font-mono); }
.text-green { color: var(--green); }
.text-red { color: var(--red); }
.text-yellow { color: var(--yellow); }
.text-muted { color: var(--text3); }
.mt-4 { margin-top: 16px; }
.mb-4 { margin-bottom: 16px; }
.fw-700 { font-weight: 700; }
.cursor-pointer { cursor: pointer; }

.loader { display: flex; align-items: center; justify-content: center; padding: 48px;
  color: var(--text3); gap: 10px; }
.spinner { width: 20px; height: 20px; border: 2px solid var(--border);
