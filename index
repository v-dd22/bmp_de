// ─── CASH FLOW ───────────────────────────────────────────────────────────
function loadCashflow() {
  const cid = window.APP.activeCompany; if (!cid) return;

  // Build a combined transactions log
  let txLog = [];
  const salesRecv = _sales.reduce((s, r) => s + (r.amtReceived || 0), 0);
  const purPaid = _purchases.reduce((s, r) => s + (r.amtPaid || 0), 0);
  const expTotal = _expenses.reduce((s, r) => s + (r.amount || 0), 0);
  const custRecTotal = _custReceipts.reduce((s, r) => s + (r.amount || 0), 0);
  const vndPayTotal = _vendorPays.reduce((s, r) => s + (r.amount || 0), 0);

  const received = salesRecv + custRecTotal;
  const paid = purPaid + vndPayTotal;
  const net = received - paid - expTotal;

  document.getElementById("cfReceived").textContent = fmt(received);
  document.getElementById("cfPaid").textContent = fmt(paid);
  document.getElementById("cfExpenses").textContent = fmt(expTotal);
  document.getElementById("cfNet").textContent = fmt(net);

  // Build log from all transaction types
  txLog = [
    ..._sales.filter(s => s.amtReceived > 0).map(s => ({
      date: s.createdAt, type: "Sale Receipt", party: s.customerName, note: s.invoiceNo,
      amount: s.amtReceived || 0, isIn: true
    })),
    ..._custReceipts.map(r => ({
      date: r.createdAt, type: "Customer Receipt", party: r.customerName, note: r.note,
      amount: r.amount || 0, isIn: true
    })),
    ..._purchases.filter(p => p.amtPaid > 0).map(p => ({
      date: p.createdAt, type: "Purchase Payment", party: p.vendorName, note: p.invoiceNo,
      amount: p.amtPaid || 0, isIn: false
    })),
    ..._vendorPays.map(r => ({
      date: r.createdAt, type: "Vendor Payment", party: r.vendorName, note: r.note,
      amount: r.amount || 0, isIn: false
    })),
    ..._expenses.map(e => ({
      date: e.createdAt, type: "Expense", party: e.category, note: e.description,
      amount: e.amount || 0, isIn: false
    }))
  ].sort((a, b) => (a.date?.seconds || 0) - (b.date?.seconds || 0));

  let running = 0;
  const tb = document.getElementById("cashflowTable");
  if (!txLog.length) { tb.innerHTML = '<tr><td colspan="6" class="empty-row">No transactions yet.</td></tr>'; return; }
  tb.innerHTML = txLog.map(tx => {
    running += tx.isIn ? tx.amount : -tx.amount;
    return `<tr>
      <td>${fmtDate(tx.date)}</td>
      <td><span class="badge ${tx.isIn ? 'badge-green' : 'badge-red'}">${tx.type}</span></td>
      <td>${tx.party || "—"}</td>
      <td>${tx.note || "—"}</td>
      <td class="text-mono fw-700 ${tx.isIn ? 'text-green' : 'text-red'}">${tx.isIn ? '+' : '-'}${fmt(tx.amount)}</td>
      <td class="text-mono fw-700 ${running >= 0 ? 'text-green' : 'text-red'}">${fmt(running)}</td>
    </tr>`;
  }).join("");
}

