async function submitPurchase() {
  const cid = window.APP.activeCompany; if (!cid) return;
  const vendorId = document.getElementById("pur_vendor").value;
  const vendorName = document.getElementById("pur_vendor").options[document.getElementById("pur_vendor").selectedIndex]?.text || "";
  if (!vendorId) { showToast("Please select a vendor", "error"); return; }

  const lines = document.querySelectorAll("#purchaseLines .item-line");
  if (!lines.length) { showToast("Add at least one item", "error"); return; }

  const items = [];
  let total = 0;
  lines.forEach(line => {
    const name = line.querySelector(".pur-pname").value;
    const qty = parseFloat(line.querySelector(".pur-qty").value) || 0;
    const unit = line.querySelector(".pur-unit").value;
    const price = parseFloat(line.querySelector(".pur-price").value) || 0;
    if (!name || !qty) return;
    const productId = name.toLowerCase().replace(/\s+/g, "_").replace(/[^a-z0-9_]/g, "");
    items.push({ productId, productName: name, qty, unit, unitPrice: price, lineTotal: qty * price });
    total += qty * price;
  });

  const payMode = document.getElementById("pur_payMode").value;
  const amtPaid = payMode === "credit" ? 0 : parseFloat(document.getElementById("pur_amtPaid").value) || total;
  const unpaid = total - amtPaid;

  await addPurchase({
    invoiceNo: document.getElementById("pur_invoice").value,
    date: document.getElementById("pur_date").value,
    vendorId, vendorName, items, total, amtPaid, unpaidAmount: unpaid,
    payMode, notes: document.getElementById("pur_notes").value
  });

  closeModal("purchaseModal");
  document.getElementById("purchaseLines").innerHTML = "";
  purLineId = 0;
  document.getElementById("purTotal").textContent = "₹0";
  setTodayDefaults();
}

