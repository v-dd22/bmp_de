    const qty = parseFloat(line.querySelector(".sal-qty").value) || 0;
    const unit = line.querySelector(".sal-unit").value;
    const price = parseFloat(line.querySelector(".sal-price").value) || 0;
    if (!name || !qty) return;
    const productId = name.toLowerCase().replace(/\s+/g, "_").replace(/[^a-z0-9_]/g, "");
    items.push({ productId, productName: name, qty, unit, unitPrice: price, lineTotal: qty * price });
    subtotal += qty * price;
  });

  const gstRate = parseFloat(document.getElementById("sal_gst").value) || 18;
  const total = subtotal * (1 + gstRate / 100);
  const payMode = document.getElementById("sal_payMode").value;
  const amtReceived = payMode === "credit" ? 0 : parseFloat(document.getElementById("sal_amtRecv").value) || total;
  const unpaid = total - amtReceived;

  await addSale({
    invoiceNo: document.getElementById("sal_invoice").value,
    date: document.getElementById("sal_date").value,
    customerId, customerName, items, subtotal, gstRate, total,
    amtReceived, unpaidAmount: unpaid,
    payMode, notes: document.getElementById("sal_notes").value
  });

  closeModal("saleModal");
  document.getElementById("saleLines").innerHTML = "";
  salLineId = 0;
  document.getElementById("salTotal").textContent = "₹0";
  setTodayDefaults();
}

