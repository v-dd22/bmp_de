// ─── EXPORT ───────────────────────────────────────────────────────────────
function exportCurrentData(type) {
  const maps = {
    purchases: _purchases.map(p => ({
      date: fmtDate(p.date || p.createdAt), invoice: p.invoiceNo, vendor: p.vendorName,
      items: (p.items||[]).length, total: p.total, paid: p.amtPaid, pending: p.unpaidAmount,
      payMode: p.payMode, notes: p.notes
    })),
    sales: _sales.map(s => ({
      date: fmtDate(s.date || s.createdAt), invoice: s.invoiceNo, customer: s.customerName,
      items: (s.items||[]).length, subtotal: s.subtotal, gstRate: s.gstRate,
      total: s.total, received: s.amtReceived, pending: s.unpaidAmount,
      payMode: s.payMode, notes: s.notes
    })),
    inventory: _inventory.map(i => ({
      product: i.productName, unit: i.unit, qty: i.qty, avgCost: i.avgCost,
      stockValue: (i.qty||0) * (i.avgCost||0)
    })),
    expenses: _expenses.map(e => ({
      date: fmtDate(e.date || e.createdAt), category: e.category,
      description: e.description, amount: e.amount, paidBy: e.paidBy
    }))
  };
  exportToCSV(maps[type], type + "_" + new Date().toISOString().split("T")[0]);
}

